# Stonewall runtime and integration environment variables

# Core Notion auth
NOTION_TOKEN=ntn_your_token_here

# Core Notion databases / data sources
NOTION_LEGAL_MATTERS_DB=YOUR_LEGAL_MATTERS_DATABASE_ID
NOTION_ALL_EMAIL_DB=YOUR_ALL_EMAIL_DATABASE_ID
NOTION_ARCHIVE_DB=YOUR_ARCHIVE_DATABASE_ID

# Optional Notion IDs used by specific scripts
NOTION_ALL_EMAIL_DS=YOUR_ALL_EMAIL_DATASOURCE_ID
NOTION_EMAIL_LEGACY_DB=YOUR_EMAIL_LEGACY_DATABASE_ID
NOTION_INCIDENTS_DB=YOUR_INCIDENTS_DATABASE_ID
NOTION_CONSOLIDATED_EMAIL_DB=YOUR_CONSOLIDATED_EMAIL_DATABASE_ID
NOTION_EMAIL_SOURCE_DS=YOUR_EMAIL_SOURCE_DATASOURCE_ID
NOTION_PARENT_PAGE=YOUR_PARENT_PAGE_ID

# OneDrive source roots
ONEDRIVE_PERSONAL_ROOT=/path/to/OneDrive
ONEDRIVE_FIRM_ROOT=/path/to/OneDrive-Firm

# Telegram bot integrations (Railway bot services)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_WEBHOOK_URL=https://your-domain.example.com/telegram/webhook

# Script/runtime options
DRY_RUN=0
SCHEMA_ONLY=0
BATCH_SIZE=200
EMAIL_DATE_START=2026-01-01
EMAIL_DATE_END=2026-12-31
STONEWALL_BASE=/workspace
FIRM_EMAIL_DOMAIN=yourfirm.com
