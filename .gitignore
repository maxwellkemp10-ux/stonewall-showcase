# OS files
.DS_Store
Thumbs.db

# Environment / secrets
.env
.env.*
!.env.example
credentials.*
.claude/settings.local.json

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/
__pycache__/
*.pyc

# Batch processing output files — contain production data, never commit
scripts/batches/*.json
matched_emails.json

# Email export artifacts — untracked to reduce repo weight
# Raw CSVs/XLSX: re-export from Outlook; consolidated JSON: rebuild via scripts/email_consolidator.mjs
sources/emails/**/*.csv
sources/emails/**/*.xlsx
sources/emails/consolidated_emails.json

# Local-only manual overrides (user-specific, never commit)
*.local.json

# Generated intake planning/report artifacts
catalog/intake/*.jsonl
catalog/intake/*_report_*.md
catalog/intake/*_report*.json
# Generated intake/sync run artifacts (ephemeral, date-stamped)
catalog/intake/notion_sync_report_*.md
catalog/intake/onedrive_notion_update_report_*.md
